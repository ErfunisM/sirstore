RewriteCond %{HTTP_REFERER} !^http://sirstore.ir/.*$      [NC]
RewriteCond %{HTTP_REFERER} !^http://sirstore.ir$      [NC]
RewriteCond %{HTTP_REFERER} !^http://www.sirstore.ir/.*$      [NC]
RewriteCond %{HTTP_REFERER} !^http://www.sirstore.ir$      [NC]
RewriteCond %{HTTP_REFERER} !^https://sirstore.ir/.*$      [NC]
RewriteCond %{HTTP_REFERER} !^https://sirstore.ir$      [NC]
RewriteCond %{HTTP_REFERER} !^https://www.sirstore.ir/.*$      [NC]
RewriteCond %{HTTP_REFERER} !^https://www.sirstore.ir$      [NC]
RewriteRule .*\.(jpg|jpeg|gif|png|bmp)$ - [F,NC]

