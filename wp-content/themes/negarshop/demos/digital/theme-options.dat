s:7:"#ff9d00";s:5:"roles";s:10:"outofstock";}}s:12:"product_tabs";a:6:{i:0;a:4:{s:6:"active";b:1;s:5:"title";s:14:"توضیحات";s:4:"slug";s:11:"description";s:8:"priority";s:2:"10";}i:1;a:4:{s:6:"active";b:1;s:5:"title";s:15:"بررسی ها";s:4:"slug";s:8:"cb_rates";s:8:"priority";s:2:"10";}i:2;a:4:{s:6:"active";b:1;s:5:"title";s:12:"مشخصات";s:4:"slug";s:22:"additional_information";s:8:"priority";s:2:"20";}i:3;a:4:{s:6:"active";b:1;s:5:"title";s:10:"نظرات";s:4:"slug";s:7:"reviews";s:8:"priority";s:2:"30";}i:4;a:4:{s:6:"active";b:0;s:5:"title";s:16:"حمل و نقل";s:4:"slug";s:8:"shipping";s:8:"priority";s:2:"12";}i:5;a:4:{s:6:"active";b:1;s:5:"title";s:29:"اطلاعات فروشنده";s:4:"slug";s:6:"seller";s:8:"priority";s:2:"90";}}s:20:"comment_upload_files";s:4:"true";s:13:"comment_title";s:80:"شما هم می‌توانید در مورد این کالا نظر بدهید.";s:12:"comment_desc";s:243:"<p>برای ثبت نظر، از طریق دکمه زیر اقدام نمایید. اگر این محصول را قبلا از نگارشاپ خریده باشید، نظر شما به عنوان مالک محصول ثبت خواهد شد.</p>";s:19:"comment_rules_title";s:120:"دیگران را با نوشتن نظرات خود، برای انتخاب این محصول راهنمایی کنید.";s:18:"comment_rules_desc";s:1092:"<p>لطفا پیش از ارسال نظر، خلاصه قوانین زیر را مطالعه کنید:</p><p>فارسی بنویسید و از کیبورد فارسی استفاده کنید. بهتر است از فضای خالی (Space) بیش‌از‌حدِ معمول، شکلک یا ایموجی استفاده نکنید و از کشیدن حروف یا کلمات با صفحه‌کلید بپرهیزید.</p><p>نظرات خود را براساس تجربه و استفاده‌ی عملی و با دقت به نکات فنی ارسال کنید؛ بدون تعصب به محصول خاص، مزایا و معایب را بازگو کنید و بهتر است از ارسال نظرات چندکلمه‌‌ای خودداری کنید.</p><p>بهتر است در نظرات خود از تمرکز روی عناصر متغیر مثل قیمت، پرهیز کنید.</p><p>به کاربران و سایر اشخاص احترام بگذارید. پیام‌هایی که شامل محتوای توهین‌آمیز و کلمات نامناسب باشند، حذف می‌شوند.</p>";s:9:"ps_active";s:4:"true";s:11:"ps_question";s:56:"آیا از قیمت های ما رضایت دارید؟";s:7:"ps_ans1";s:6:"بله";s:7:"ps_ans2";s:6:"خیر";s:7:"ps_desc";s:61:"این کالا را با چه قیمتی دیده‌اید؟";s:8:"ps_desc2";s:58:"آدرس اینترنتی یا واقعی فروشگاهی";s:9:"ps_thanks";s:51:"از شما بابت همکاری متشکریم...";s:16:"ribb_stock_color";s:7:"#222222";s:15:"ribb_sale_color";s:7:"#222222";s:13:"ribb_3d_color";s:7:"#222222";s:15:"product_ribbons";a:1:{i:0;a:5:{s:6:"active";b:1;s:3:"def";b:0;s:5:"color";s:7:"#f9cb15";s:5:"title";s:16:"اورجینال";s:4:"icon";s:11:"fa fa-check";}}s:13:"delivery_desc";s:463:"<p>با توجه به اینکه ارسال کالاهای این فروشنده توسط فروشگاه اصلی انجام می‌شود، رویه‌های ارسال این فروشنده همانند رویه‌های ارسال فروشگاه اصلی می‌باشد.<br />شما می‌توانید رویه‌های ارسال فروشگاه اصلی را در لینک زیر مشاهده کنید:</p><p><a href="#">رویه‌های ارسال</a></p>";s:21:"account_tab_dashboard";b:1;s:26:"account_tab_dashboard_name";s:14:"پیشخوان";s:18:"account_tab_orders";b:1;s:23:"account_tab_orders_name";s:15:"سفارش ها";s:21:"account_tab_downloads";b:1;s:26:"account_tab_downloads_name";s:17:"دانلود ها";s:24:"account_tab_edit-address";b:1;s:29:"account_tab_edit-address_name";s:13:"آدرس ها";s:27:"account_tab_payment-methods";b:1;s:32:"account_tab_payment-methods_name";s:26:"روش هاي پرداخت";s:24:"account_tab_edit-account";b:1;s:29:"account_tab_edit-account_name";s:36:"اطلاعات حساب كاربری";s:22:"account_tab_negar-favs";b:1;s:27:"account_tab_negar-favs_name";s:24:"علاقه مندی ها";s:23:"wordpress_widgets_style";s:7:"classic";s:30:"wordpress_widgets_header_style";s:4:"bold";s:15:"sb_widget_items";a:0:{}s:23:"blog_single_comment_adv";s:8:"advanced";s:12:"blog_sidebar";s:4:"left";s:18:"blogsingle_sidebar";s:4:"left";s:12:"login_header";s:5:"false";s:23:"products_archive_slider";s:5:"false";s:28:"products_archive_slider_text";s:31:"محصولات پیشنهادی";s:36:"products_archive_orders_header_style";s:7:"classic";s:30:"products_archive_orderby_style";s:3:"tab";s:35:"products_archive_orderby_tab-picker";a:1:{s:3:"tab";a:1:{s:5:"style";s:7:"classic";}}s:29:"products_archive_stock_filter";s:4:"true";s:30:"products_archive_active_filter";s:4:"true";s:13:"sort_by_stock";s:5:"false";s:26:"products_archive_res_count";s:1:"2";s:28:"products_archive_sideb